{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "gcx On-Prem OAuth",
  "id": "joshuagrisham-gcxonpremoauth-app",
  "backend": true,
  "autoEnabled": true,
  "executable": "gpx_joshuagrisham_gcxonpremoauth_app",
  "info": {
    "keywords": ["gcx", "mcp-grafana", "cli", "on-prem", "oauth", "authentication"],
    "description": "A Grafana app for managing On-Prem OAuth user authentication for use with gcx, mcp-grafana, and other client applications",
    "author": {
      "name": "Joshua Grisham"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "Website",
        "url": "https://github.com/joshuagrisham/grafana-gcx-on-prem-oauth-plugin"
      },
      {
        "name": "Source",
        "url": "https://github.com/joshuagrisham/grafana-gcx-on-prem-oauth-plugin"
      },
      {
        "name": "License",
        "url": "https://github.com/joshuagrisham/grafana-gcx-on-prem-oauth-plugin/blob/main/LICENSE"
      },
      {
        "name": "Report an issue",
        "url": "https://github.com/joshuagrisham/grafana-gcx-on-prem-oauth-plugin/issues"
      }
    ],
    "screenshots": [
      {
        "name": "Menu page",
        "path": "img/screenshots/menu.png"
      },
      {
        "name": "Manage user tokens page",
        "path": "img/screenshots/manage-user-tokens.png"
      },
      {
        "name": "Client setup page",
        "path": "img/screenshots/client-setup.png"
      },
      {
        "name": "CLI sign-in success",
        "path": "img/screenshots/cli-connected.png"
      }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Menu",
      "path": "/a/%PLUGIN_ID%/menu",
      "defaultNav": true,
      "addToNav": true
    },
    {
      "type": "page",
      "name": "Authorize",
      "path": "/a/%PLUGIN_ID%/authorize",
      "addToNav": false
    },
    {
      "type": "page",
      "icon": "key-skeleton-alt",
      "name": "Manage user tokens",
      "path": "/a/%PLUGIN_ID%/tokens",
      "addToNav": true
    },
    {
      "type": "page",
      "icon": "rocket",
      "name": "Client setup",
      "path": "/a/%PLUGIN_ID%/client-setup",
      "addToNav": true
    },
    {
      "type": "page",
      "icon": "key-skeleton-alt",
      "name": "Manage all user service accounts",
      "path": "/org/serviceaccounts",
      "role": "Admin",
      "addToNav": true
    },
    {
      "type": "page",
      "icon": "cog",
      "name": "Plugin configuration",
      "path": "/plugins/%PLUGIN_ID%",
      "role": "Admin",
      "addToNav": true
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=11.0.0",
    "plugins": []
  }
}
